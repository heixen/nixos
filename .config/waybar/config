    "clock#date": {
        "interval": 10,
        "format": "{:%a %b %e %R}",
        "tooltip-format": "{:%e %B %Y}",
        "on-click": "exec gnome-calendar"
    },
    "cpu": {
        "interval": 5,
        "format": "{icon} {usage}%",
        "format-icons": ["’ŗø "],
        "states": {
            "warning": 70,
            "critical": 90
        }
    },
    "custom/keyboard-layout": {
        "exec": "hyprctl -j devices | jq -r '.keyboards[0].active_keymap // \"Unknown\"'",
        "interval": 30,
        "format": "’ä£  {}",
