{
    "layer": "top",
    "position": "top",
    "height": 28,
    // "output": "HDMI-A-1",
    "modules-left": [
        "hyprland/workspaces"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "network",
        "bluetooth",
        "pulseaudio",
        "battery",
        "clock#date",
        "tray"
    ],
    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "’ā¦ {icon} {capacity}%",
