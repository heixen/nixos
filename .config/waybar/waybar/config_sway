{
    //sway
    "layer": "top",
    "position": "top",
    "height": 28,

    "modules-left": [
        "sway/workspaces"
    ],
    "modules-center": [
        "sway/window"
    ],
    "modules-right": [
        "cpu",
        "memory",
        "network",
        "bluetooth",
        "battery",
        "clock#date",
        "tray"
    ],

    "sway/workspaces": {
        "disable-scroll": true,
        "format": "{icon}",
        "format-icons": {
            "urgent": "яБк",
            "focused": "тмд",
            "default": "тЧп"
        }
    },

    "sway/window": {
        "format": "{title}",
        "max-length": 50
    },

    "battery": {
        "interval": 10,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "яГз {icon} {capacity}%",
        "format-discharging": "{icon} {capacity}%",
        "format-icons": [
            "яЙД ",
            "яЙГ ",
            "яЙВ ",
            "яЙБ ",
            "яЙА "
        ],
        "tooltip": true,
        "tooltip-format": "{timeTo} : {capacity}%"
    },

    "clock#date": {
        "interval": 10,
        "format": "{:%a %b %e %R}",
        "tooltip-format": "{:%e %B %Y}",
        "on-click": "gnome-calendar"
    },

    "cpu": {
        "interval": 5,
        "format": "яЛЫ {usage}%",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "memory": {
        "interval": 5,
        "format": "яФ╕ {}%",
        "states": {
            "warning": 70,
            "critical": 90
        }
    },

    "network": {
        "interval": 2,
        "format-wifi": "яЗл {bandwidthDownBytes} тЖУ {bandwidthUpBytes} тЖС",
        "format-ethernet": "яЮЦ {bandwidthDownBytes} тЖУ {bandwidthUpBytes} тЖС",
        "format-disconnected": "тЪа Disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}\nDown: {bandwidthDownBytes}\nUp: {bandwidthUpBytes}",
        "on-click": "kitty nmtui"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "яАж",
        "format-icons": {
            "default": ["яАз", "яАи"]
        },
        "on-click": "pavucontrol"
    },

    "bluetooth": {
        "format": "ґ░Вп",
        "format-disabled": "ґ░В▓",
        "on-click-right": "kitty bluetuith"
    },

    "temperature": {
        "critical-threshold": 80,
        "interval": 5,
        "format": "{icon} {temperatureC}┬░C",
        "format-icons": [
            "яЛЛ",
            "яЛК",
            "яЛЙ",
            "яЛИ",
            "яЛИ"
        ]
    },

    "tray": {
        "icon-size": 21,
        "spacing": 10
    }
}
